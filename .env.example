# ---------------------------------------------------------------
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------

# A long random string used to sign session cookies.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ---------------------------------------------------------------
# Database - choose ONE of the two options below.
# ---------------------------------------------------------------

# Option A: single connection URL (used by Render and most cloud platforms)
# PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/wedding_db
# MySQL/MariaDB:
# DATABASE_URL=mysql://user:password@host:3306/wedding_db

# Option B: individual settings (used for local / Docker deployments)
# DB_TYPE selects the database engine: mariadb (default) or postgres
DB_TYPE=mariadb
DB_HOST=localhost
DB_PORT=3306
DB_USER=wedding_user
DB_PASS=wedding_password
DB_NAME=wedding_db

# For PostgreSQL, change DB_TYPE and DB_PORT:
# DB_TYPE=postgres
# DB_PORT=5432
