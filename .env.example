# ---------------------------------------------------------------
# Copy this file to .env and fill in your values.
# Used for local/venv deployments only.
# ---------------------------------------------------------------

# A long random string used to sign session cookies.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ---------------------------------------------------------------
# PostgreSQL connection - change DB_PASS value before deploying.
#
# Generate a random password with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# ---------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=matrimony-user
DB_PASS=change-me
DB_NAME=matrimon-db

# Optional: pre-set the wedding timezone (IANA zone name, e.g. Australia/Hobart).
# This becomes the default selected in the setup wizard and the initial DB value.
# Can always be changed later in Admin > Wedding Settings.
# DEFAULT_TIMEZONE=UTC

# Optional: host port the app listens on (default 8000)
# APP_PORT=8000
