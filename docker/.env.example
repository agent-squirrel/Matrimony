# ---------------------------------------------------------------
# Copy this file to docker/.env and fill in your values.
# Used for Docker deployments only.
# (DB_HOST and DB_PORT are set by docker-compose.yml - not needed here.)
# ---------------------------------------------------------------

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Generate passwords with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# WARNING: change these before starting the containers - defaults are public.
DB_USER=change-me
DB_PASS=change-me
DB_NAME=wedding_db

# Optional: host port the app listens on (default 8000)
# APP_PORT=8000
