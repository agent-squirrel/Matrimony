# ---------------------------------------------------------------
# Copy this file to docker/.env and fill in your values.
# Used for Docker deployments only.
# ---------------------------------------------------------------

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Generate passwords with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# WARNING: change DB_PASS before starting the containers
DB_HOST=localhost
DB_PORT=5432
DB_USER=matrimony-user
DB_PASS=change-me
DB_NAME=matrimony-db

# Optional: pre-set the wedding timezone (IANA zone name, e.g. Australia/Hobart).
# This becomes the default selected in the setup wizard and the initial DB value.
# Can always be changed later in Admin > Wedding Settings.
# DEFAULT_TIMEZONE=UTC

# Optional: host port the app listens on (default 8000)
# APP_PORT=8000
